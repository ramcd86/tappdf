# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# Payments are mocked by default. Set to false only when enabling real Stripe.
PAYMENT_MOCK_MODE=true

# Vercel Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_your_token
POSTGRES_URL=postgres://your_connection_string
POSTGRES_PRISMA_URL=postgres://your_prisma_connection_string
POSTGRES_URL_NON_POOLING=postgres://your_non_pooling_connection_string

# App Configuration
BASE_URL=http://localhost:3000
PAYMENT_AMOUNT=99
PAYMENT_CURRENCY=eur
FILE_EXPIRY_HOURS=24
